{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-conventions.mjs\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "model": "claude-haiku-4-5-20251001",
            "if": "Bash(git commit*)",
            "continueOnBlock": true,
            "statusMessage": "Conventional commits check...",
            "prompt": "Review this git commit command: $ARGUMENTS\n\nCheck if the commit message follows Conventional Commits format: type(scope?): description\nAllowed types: feat, fix, docs, style, refactor, test, chore, build, ci, perf\n\nIf the message does NOT follow this format, set ok to false and in reason provide a corrected command: 'Gebruik dit: git commit -m \"<corrected conventional message>\"'\n\nIf it already follows the format, set ok to true."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-conventions.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-commit.sh\""
          }
        ]
      }
    ]
  }
}
